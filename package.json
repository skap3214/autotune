{
  "name": "autotune",
  "version": "0.1.0",
  "description": "Agentic trace capture and merge CLI",
  "type": "module",
  "bin": {
    "autotune": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "cli",
    "agents",
    "traces",
    "rl"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "inquirer": "^13.3.2",
    "nanoid": "^5.1.7"
  }
}
